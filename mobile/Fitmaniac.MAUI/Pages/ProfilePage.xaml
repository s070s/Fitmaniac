<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fitmaniac.MAUI.Pages.ProfilePage"
             Title="Profile">

    <VerticalStackLayout Padding="24" Spacing="16" VerticalOptions="Center">
        <Label Text="Profile" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" />
        <Button Text="Logout" Command="{Binding LogoutCommand}" BackgroundColor="Red" TextColor="White" />
    </VerticalStackLayout>
</ContentPage>
