<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fitmaniac.MAUI.Pages.RegisterPage"
             Title="Register">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="16" VerticalOptions="Center">
            <Label Text="Create Account" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" />

            <Entry Placeholder="Username" Text="{Binding Username}" />
            <Entry Placeholder="Email" Text="{Binding Email}" Keyboard="Email" />
            <Entry Placeholder="Password" Text="{Binding Password}" IsPassword="True" />

            <Label Text="{Binding ErrorMessage}" TextColor="Red" IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotNullOrEmpty}}" />

            <Button Text="Register" Command="{Binding RegisterCommand}" IsEnabled="{Binding IsNotBusy}" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />

            <Button Text="Back to Login" Command="{Binding GoToLoginCommand}" BackgroundColor="Transparent" TextColor="{StaticResource Primary}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
