<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fitmaniac.MAUI.Pages.LoginPage"
             Title="Login">
    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="16" VerticalOptions="Center">
            <Label Text="Fitmaniac" FontSize="36" FontAttributes="Bold" HorizontalOptions="Center" />

            <Entry Placeholder="Email" Text="{Binding Email}" Keyboard="Email" />
            <Entry Placeholder="Password" Text="{Binding Password}" IsPassword="True" />

            <Label Text="{Binding ErrorMessage}" TextColor="Red" IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotNullOrEmpty}}" />

            <Button Text="Login" Command="{Binding LoginCommand}" IsEnabled="{Binding IsNotBusy}" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />

            <Button Text="Create Account" Command="{Binding GoToRegisterCommand}" BackgroundColor="Transparent" TextColor="{StaticResource Primary}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
