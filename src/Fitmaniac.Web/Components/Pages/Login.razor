@page "/login"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@inject IAuthConsumer AuthConsumer
@inject Fitmaniac.Web.Services.WebAuthService WebAuth
@inject NavigationManager Nav

<PageTitle>Login — Fitmaniac</PageTitle>
<div class="row justify-content-center">
    <div class="col-md-4">
        <h2 class="mb-4">Sign In</h2>
        <EditForm Model="_model" OnValidSubmit="HandleLogin" FormName="login">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label">Username or Email</label>
                <InputText @bind-Value="_model.UsernameOrEmail" class="form-control" />
            </div>
            <div class="mb-3">
                <label class="form-label">Password</label>
                <InputText @bind-Value="_model.Password" type="password" class="form-control" />
            </div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="alert alert-danger">@_error</div>
            }

            <button type="submit" class="btn btn-primary w-100" disabled="@_busy">
                @(_busy ? "Signing in..." : "Sign In")
            </button>
        </EditForm>
        <div class="mt-3 text-center">
            <a href="/register">Create an account</a> |
            <a href="/forgot-password">Forgot password?</a>
        </div>
    </div>
</div>

@code {
    private readonly LoginFormModel _model = new();
    private string? _error;
    private bool _busy;

    private async Task HandleLogin()
    {
        _busy = true;
        _error = null;
        var result = await AuthConsumer.LoginAsync(new LoginRequestDto(_model.UsernameOrEmail, _model.Password));
        if (result?.Success == true)
        {
            await WebAuth.SignInAsync(result);
            Nav.NavigateTo("/");
        }
        else
        {
            _error = string.Join(", ", result?.Errors ?? ["Login failed."]);
        }
        _busy = false;
    }

    private sealed class LoginFormModel
    {
        public string UsernameOrEmail { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
